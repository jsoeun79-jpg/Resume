<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Soeun Jeong - Resume</title>
  <style>
    :root {
      --bg: #f4f7fb;
      --card: #ffffff;
      --text: #1f2937;
      --accent: #2563eb;
      --accent-soft: #dbeafe;
    }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: var(--bg);
      color: var(--text);
      padding: 32px 16px;
    }

    .resume {
      max-width: 900px;
      margin: auto;
      background: white;
      border-radius: 16px;
      overflow: hidden;
      border: 1px solid #e5e7eb;
    }

    .topbar {
      background: #2563eb;
      color: white;
      padding: 30px;
    }

    .name {
      font-size: 2rem;
      margin: 0;
    }

    .contact {
      margin-top: 10px;
      font-size: 0.9rem;
    }

    .content {
      display: grid;
      grid-template-columns: 1fr 2fr;
    }

    .sidebar {
      padding: 20px;
      background: #f9fafb;
    }

    .main {
      padding: 20px;
    }

    .section-title {
      color: var(--accent);
      font-weight: bold;
      margin-bottom: 10px;
    }

    .tag {
      display: inline-block;
      background: var(--accent-soft);
      padding: 5px 10px;
      border-radius: 999px;
      margin: 3px;
      font-size: 0.8rem;
    }

    ul {
      padding-left: 18px;
    }
  </style>
</head>

<body>

<div class="resume">

  <div class="topbar">
    <h1 class="name">Soeun Jeong</h1>
    <div class="contact">
      114035195 | Korean | Taichung | Asia University<br>
      📧 qazwsxc66231@naver.com | +886 4 2332 3456
    </div>
  </div>

  <div class="content">

    <div class="sidebar">
      <div class="section-title">Profile</div>
      <p>Business & Marketing student at Asia University.</p>

      <div class="section-title">Skills</div>
      <span class="tag">Korean</span>
      <span class="tag">English</span>
    </div>

    <div class="main">

      <div class="section-title">Education</div>
      <p>Asia University (2026 Expected Graduation)</p>

      <div class="section-title">Academic Background</div>
      <ul>
        <li>Business fundamentals</li>
        <li>Marketing concepts</li>
        <li>Information technology</li>
      </ul>

    </div>

  </div>

</div>

</body>
</html>
